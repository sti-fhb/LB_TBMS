flowchart TB
    REQ(["POST /api/lb/task<br/>:9200"]) --> TOKEN{"Bearer Token<br/>驗證"}

    TOKEN -->|失敗| R401["401 Unauthorized"]
    TOKEN -->|通過| PARSE["解析 JSON Body"]
    PARSE -->|格式錯誤| R400["400 Invalid JSON"]
    PARSE -->|OK| UUID_CHK{"uuid 欄位<br/>存在?"}
    UUID_CHK -->|無| R400B["400 uuid required"]
    UUID_CHK -->|有| WRITE_LOG["寫入<br/>LB_PRINT_LOG_CACHE"]

    WRITE_LOG --> STATUS_CHK{"body.status?"}
    STATUS_CHK -->|"0（預設）"| ONQ["INSERT<br/>ONLINE_QUEUE"]
    STATUS_CHK -->|"2"| OFFQ["INSERT<br/>OFFLINE_QUEUE"]

    ONQ --> NOTIFY["放 1 個通知進佇列<br/>queue.put('task_received')"]
    OFFQ --> NOTIFY

    NOTIFY --> R200["200 OK<br/>{success: true, uuid}"]

    subgraph MAIN_THREAD["Main Thread（每 200ms 檢查通知佇列）"]
        POLL["_poll_task_events()"] --> GET["queue.get_nowait()<br/>取通知"]
        GET --> REFRESH["_refresh_queues()<br/>重載 ListBox"]
        GET --> MSG["_add_msg<br/>('收到新列印指令')"]
    end

    NOTIFY -.->|"通知佇列<br/>(thread-safe)"| POLL

    style REQ fill:#2E86C1,stroke:#1A5276,color:#FFF
    style R200 fill:#27AE60,stroke:#1E8449,color:#FFF
    style R401 fill:#CC0000,stroke:#922B21,color:#FFF
    style R400 fill:#CC0000,stroke:#922B21,color:#FFF
    style R400B fill:#CC0000,stroke:#922B21,color:#FFF
    style MAIN_THREAD fill:#E8F4FD,stroke:#2E86C1,stroke-width:2px
    style NOTIFY fill:#F5B041,stroke:#D35400,color:#333
