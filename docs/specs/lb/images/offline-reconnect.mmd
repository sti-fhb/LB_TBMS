    START(["LBSB01 啟動<br/>authenticate() 載入 HARDCODED_TOKEN<br/>（無健康檢查 ping）"]) --> FIRSTSYNC["主畫面開啟後<br/>首次同步（_do_sync）<br/>Call APILB"]

