%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#D6E4F0', 'primaryTextColor': '#003366', 'primaryBorderColor': '#1A5276', 'lineColor': '#2E86C1', 'fontSize': '13px'}}}%%
flowchart TB
    START(["LBSB01 啟動"]) --> AUTH["authenticate()<br/>APIDP001 認證"]
    AUTH --> CHECK{認證成功?}

    CHECK -->|YES| ONLINE["<b>線上模式</b><br/>session.online = True<br/>標題【線上】🟢"]
    CHECK -->|NO| OFFLINE["<b>離線模式</b><br/>session.online = False<br/>標題【離線】🔴"]

    OFFLINE --> TIMER["啟動重連計時器<br/>every 60 秒"]
    TIMER -->|"60s 後"| RETRY["authenticate()<br/>重新認證"]
    RETRY --> RECHECK{認證成功?}

    RECHECK -->|NO| TIMER
    RECHECK -->|YES| SWITCH["切換為線上模式<br/>更新標題 + 狀態燈"]
    SWITCH --> SYNC["_sync_local_to_db()<br/>replay PENDING_OPS"]
    SYNC --> REFRESH["全量刷新 Local Cache<br/>以中央 DB 為準"]
    REFRESH --> ONLINE

    subgraph OFFLINE_OPS["離線期間仍可操作"]
        OP1["✅ 標籤測試頁<br/>（localhost:9200）"]
        OP2["✅ Queue 操作<br/>（移動 / 刪除）"]
        OP3["✅ 印表機設定<br/>（寫 Cache + PENDING_OPS）"]
        OP4["✅ GoDEX 列印<br/>（USB / TCP 直連）"]
    end

    OFFLINE -.-> OFFLINE_OPS

    style START fill:#2E86C1,stroke:#1A5276,color:#FFF
    style ONLINE fill:#27AE60,stroke:#1E8449,color:#FFF,stroke-width:2px
    style OFFLINE fill:#CC0000,stroke:#922B21,color:#FFF,stroke-width:2px
    style SWITCH fill:#27AE60,stroke:#1E8449,color:#FFF
    style SYNC fill:#F5B041,stroke:#D35400,color:#333
    style REFRESH fill:#F5B041,stroke:#D35400,color:#333
    style OFFLINE_OPS fill:#FEF9E7,stroke:#D4AC0D,stroke-width:1px
